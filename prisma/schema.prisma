generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  handleName   String     @unique
  bio          String?
  interestTags String[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  hooks        Hook[]
  wikiEdits    WikiEdit[]
}

model Place {
  id          String     @id @default(cuid())
  name        String
  description String?
  address     String?
  lat         Float
  lng         Float
  tags        String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  hooks       Hook[]
  wikiEdits   WikiEdit[]
}

model Hook {
  id          String   @id @default(cuid())
  userId      String?
  placeId     String
  message     String
  tags        String[]
  hookType    HookType @default(RECENT)
  isAnonymous Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model WikiEdit {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum HookType {
  REGULAR
  RECENT
}
